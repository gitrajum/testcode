# Environment Configuration for ElsaMcp

# Server Configuration
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Azure AD Authentication
# Required for production deployment - validates tokens from A2A agents
MCP_AUTH_ENABLED=true
AZURE_TENANT_ID=<ID>
MANAGED_IDENTITY_CLIENT_ID=<ID>

# Note: Set MCP_AUTH_ENABLED=false to disable auth for local development

# Telemetry (Optional)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=elsa-mcp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Databricks Connection (ELSA UC3)
DATABRICKS_SERVER_HOSTNAME=adb-<workspace-id>.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>
DATABRICKS_ACCESS_TOKEN=dapi<your-token-here>
DATABRICKS_CATALOG=<catalog-name>
DATABRICKS_SCHEMA=<schema-name>

# Databricks Proxy (optional, set USE_PROXY=true to enable)
DATABRICKS_USE_PROXY=false
DATABRICKS_PROXY_HOST=azureproxyeu.azure.cnb
DATABRICKS_PROXY_PORT=8080
